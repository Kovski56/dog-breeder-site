# Gmail / SMTP settings for the puppy inquiry form.
# Copy this file to ".env.local" and fill in real values.
# .env.local is gitignored, so your password never gets committed.

# The Gmail address that SENDS the inquiry emails.
SMTP_USER=youraccount@gmail.com

# A Google "App Password" (16 characters) — NOT your normal Gmail password.
# Create one at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the Google account).
SMTP_PASS=your16charapppassword

# Where inquiries are delivered — the breeder's inbox.
INQUIRY_TO=breeder@example.com

# Optional overrides (defaults shown). Use port 587 if 465 is blocked.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
